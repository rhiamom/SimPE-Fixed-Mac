  <ItemGroup>
    <ProjectReference Include="..\Ambertation.3D\ambertation.3D.csproj" />
    <ProjectReference Include="..\Ambertation.Utilities\ambertation.utilities.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Ambertation.3D.Gl.Binding\ambertation.3D.Gl.Binding.csproj" />
  </ItemGroup>

  <!-- Copy simpe.ngbh under its alias names to all required output locations -->
  <Target Name="SimPeNgbhCopyAliases" AfterTargets="Build">
    <PropertyGroup>
      <_NgbhMainBin Condition=" '$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*' ">$(SolutionDir)SimPE.Main\bin\$(Configuration)\</_NgbhMainBin>
    </PropertyGroup>

    <!-- Local: /bin/Plugins -->
    <MakeDir Directories="$(TargetDir)Plugins" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(TargetDir)Plugins\simpe.ngbh.dll" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(TargetDir)simpe.ngbh.plugin.dll" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(TargetDir)Plugins\simpe.ngbh.plugin.dll" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(TargetDir)Plugins\simpe.ngbh.pdb"
          SkipUnchangedFiles="true" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(TargetDir)simpe.ngbh.plugin.pdb"
          SkipUnchangedFiles="true" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(TargetDir)Plugins\simpe.ngbh.plugin.pdb"
          SkipUnchangedFiles="true" Condition="Exists('$(TargetDir)$(TargetName).pdb')" />

    <!-- Unified bin\Plugins (solution build only) -->
    <MakeDir Directories="$(SimPeUnifiedOutDir)Plugins" Condition=" '$(SimPeUnifiedOutDir)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(SimPeUnifiedOutDir)Plugins\simpe.ngbh.dll"
          SkipUnchangedFiles="true" Condition=" '$(SimPeUnifiedOutDir)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(SimPeUnifiedOutDir)Plugins\simpe.ngbh.plugin.dll"
          SkipUnchangedFiles="true" Condition=" '$(SimPeUnifiedOutDir)' != '' " />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(SimPeUnifiedOutDir)Plugins\simpe.ngbh.pdb"
          SkipUnchangedFiles="true" Condition=" '$(SimPeUnifiedOutDir)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(SimPeUnifiedOutDir)Plugins\simpe.ngbh.plugin.pdb"
          SkipUnchangedFiles="true" Condition=" '$(SimPeUnifiedOutDir)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />

    <!-- SimPE.Main\bin and SimPE.Main\bin\Plugins (solution build only) -->
    <MakeDir Directories="$(_NgbhMainBin)Plugins" Condition=" '$(_NgbhMainBin)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(_NgbhMainBin)simpe.ngbh.dll"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(_NgbhMainBin)Plugins\simpe.ngbh.dll"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(_NgbhMainBin)simpe.ngbh.plugin.dll"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' " />
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(_NgbhMainBin)Plugins\simpe.ngbh.plugin.dll"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' " />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(_NgbhMainBin)simpe.ngbh.pdb"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(_NgbhMainBin)Plugins\simpe.ngbh.pdb"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(_NgbhMainBin)simpe.ngbh.plugin.pdb"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />
    <Copy SourceFiles="$(TargetDir)$(TargetName).pdb" DestinationFiles="$(_NgbhMainBin)Plugins\simpe.ngbh.plugin.pdb"
          SkipUnchangedFiles="true" Condition=" '$(_NgbhMainBin)' != '' And Exists('$(TargetDir)$(TargetName).pdb')" />
  </Target>

  <ItemGroup>
    <ProjectReference Include="..\AdvancedForms\AdvancedForms.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\NetDocks\NetDocks.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\xsi.lib\xsi.lib.csproj" />
  </ItemGroup>
</Project>