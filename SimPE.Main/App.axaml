<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SimPe.App"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelected"             Color="#5580C4" />
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelectedPointerOver"  Color="#7099D4" />
        <SolidColorBrush x:Key="TreeViewItemBackgroundSelectedPressed"      Color="#4470B4" />
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="avares://AvaloniaHex/Themes/Simple/AvaloniaHex.axaml"/>
        <!-- Classic raised Windows-style tabs -->
        <Style Selector="TabControl">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <ControlTemplate>
                    <DockPanel>
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        DockPanel.Dock="{TemplateBinding TabStripPlacement}"
                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                        <Border Background="White"
                                BorderBrush="#7A7A7A"
                                BorderThickness="1">
                            <ContentPresenter Name="PART_SelectedContentHost"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              Margin="4" />
                        </Border>
                    </DockPanel>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="Bd"
                            Background="#E0E0E0"
                            BorderBrush="#7A7A7A"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0"
                            Margin="2,2,2,0"
                            Padding="8,3">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Panel.ZIndex" Value="10" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="White"
                            BorderBrush="#7A7A7A"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0"
                            Margin="2,0,2,-1"
                            Padding="8,3">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          FontWeight="SemiBold"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem:pointerover:not(:selected)">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="#CDCDCD"
                            BorderBrush="#7A7A7A"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0"
                            Margin="2,2,2,0"
                            Padding="8,3">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <!-- Compact input controls — Fluent default MinHeight is too tall -->
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding"   Value="6,2" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding"   Value="6,2" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding"   Value="6,2" />
        </Style>
        <Style Selector="NumericUpDown /template/ TextBox">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding"   Value="4,2" />
        </Style>
        <!-- TreeView selection — match DataGrid row selection colour -->
        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#5580C4" />
        </Style>
        <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot:pointerover">
            <Setter Property="Background" Value="#7099D4" />
        </Style>
        <!-- Muted steel-blue DataGrid row selection instead of garish accent blue -->
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill"    Value="#5580C4" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="DataGridRow:selected:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill"    Value="#7099D4" />
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Application.Styles>
</Application>
